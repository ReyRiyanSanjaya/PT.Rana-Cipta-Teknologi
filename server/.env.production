PORT=4000
NODE_ENV=production

# ===== GANTI DENGAN KREDENSIAL DATABASE POSTGRESQL DARI CPANEL =====
# Format: postgresql://USERNAME:PASSWORD@localhost:5432/DATABASE_NAME
DATABASE_URL=postgresql://norulesbp_ranauser:PASSWORD_DB@localhost:5432/norulesbp_ranadb

# JWT Secret (jangan diubah setelah production)
JWT_SECRET=7c0b53788d8566e9b72cfd8265d312cee3440fa96cf14848a457ae129800bfd5fca4cf463a219094e581fa99ad5092d3eff91924d48eb1f98c5786231e43a4d9

# Admin Seed Account
ADMIN_EMAIL=admin@rana.web.id
ADMIN_PASSWORD=Admin!12345

# CORS — semua frontend yang diizinkan
ALLOWED_ORIGINS=https://rana.web.id,https://www.rana.web.id,https://app.rana.web.id,https://admin.rana.web.id,https://distributor.rana.web.id

# Chat message retention (168 jam = 7 hari)
CHAT_RETENTION_HOURS=168

# Digiflazz PPOB (isi jika sudah punya akun)
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com/v1
DIGIFLAZZ_MODE=production
DIGIFLAZZ_MARKUP_FLAT=0
DIGIFLAZZ_MARKUP_PERCENT=0
DIGIFLAZZ_WEBHOOK_SECRET=

# OpenAI (isi jika ingin fitur AI aktif)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Logging
LOG_LEVEL=info

# Encryption Key
SETTINGS_ENCRYPTION_KEY=

# Firebase (isi jika ingin push notification aktif)
FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=rana-driver-app
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
