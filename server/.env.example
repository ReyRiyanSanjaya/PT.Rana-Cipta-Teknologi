# ================================
# Rana Market — Environment Configuration
# ================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# Server
PORT=4000
NODE_ENV=development

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/rana_pos?schema=public"

# JWT Secret (REQUIRED — server will NOT start without this)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Admin Seed Account
ADMIN_EMAIL=admin@rana.id
ADMIN_PASSWORD=

# CORS — Comma-separated list of allowed frontend origins
# Leave empty to use defaults (localhost:5173, 5174, 5175)
ALLOWED_ORIGINS=

# Chat message retention (in hours, default: 168 = 7 days)
CHAT_RETENTION_HOURS=168

# Digiflazz PPOB Integration (optional)
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com/v1
DIGIFLAZZ_MODE=production
DIGIFLAZZ_MARKUP_FLAT=0
DIGIFLAZZ_MARKUP_PERCENT=0

# Settings Encryption Key (optional, for encrypting sensitive DB settings)
# If not set, JWT_SECRET is used as fallback
SETTINGS_ENCRYPTION_KEY=

# ================================
# Firebase Cloud Messaging (FCM)
# ================================
# For push notifications to driver app
# Get from: Firebase Console > Project Settings > Cloud Messaging > Server Key
FCM_SERVER_KEY=

# Firebase Project ID
FIREBASE_PROJECT_ID=

# Firebase Service Account JSON path (for admin SDK)
# Download from: Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
