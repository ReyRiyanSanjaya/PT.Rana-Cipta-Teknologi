# ============================================
# RANA DRIVER - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# This file should NOT be committed to git
# ============================================

# ==========================================
# API Configuration
# ==========================================
# Production API URL
API_BASE_URL=https://api.rana-app.com/api

# Set to true for production builds
RANA_PROD=false

# ==========================================
# Firebase Configuration
# ==========================================
# Download google-services.json from Firebase Console
# Place at: android/app/google-services.json
#
# Firebase Project ID
FIREBASE_PROJECT_ID=rana-driver-app

# FCM Server Key (for server-side push)
# Get from: Firebase Console > Project Settings > Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here

# ==========================================
# App Signing (Android)
# ==========================================
# Generate keystore:
# keytool -genkey -v -keystore rana-driver.jks -keyalg RSA -keysize 2048 -validity 10000 -alias rana-driver
#
# Then create android/key.properties with:
# storePassword=YOUR_PASSWORD
# keyPassword=YOUR_PASSWORD
# keyAlias=rana-driver
# storeFile=/path/to/rana-driver.jks

# ==========================================
# Play Store
# ==========================================
PLAY_STORE_PACKAGE_NAME=com.rana.driver
PLAY_STORE_APP_NAME=Rana Driver

# ==========================================
# Development Helpers
# ==========================================
# Your local machine IP (for testing on physical device)
# Find with: ipconfig (Windows) or ifconfig (Mac/Linux)
LOCAL_DEV_IP=192.168.1.x

# Server port (default 4000)
SERVER_PORT=4000
